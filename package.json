    "test:beer": "tsc && jest --runInBand --detectOpenHandles --forceExit src/tests/routes/beer.routes.test.ts",
    "test:post": "tsc && jest --runInBand --detectOpenHandles --forceExit src/tests/routes/post.routes.test.ts",
    "test:user": "tsc && jest --runInBand --detectOpenHandles --forceExit src/tests/routes/user.routes.test.ts",
